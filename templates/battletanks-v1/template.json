{
  "id": "battletanks-v1",
  "version": "1.0.0",
  "upstream": {
    "repo": "https://github.com/EGalahad/BattleTanks",
    "commit": "2d0221f6470c15b9af67ab9e20d88848f1b58048",
    "sourceType": "threejs-typescript"
  },
  "capabilities": [
    "auth",
    "multiplayer",
    "leaderboard",
    "publish",
    "r3f"
  ],
  "immutablePaths": [
    "core-engine/**",
    "assets/**",
    "tests/runtime-gates/**"
  ],
  "editablePaths": [
    "gameplay/**",
    "adapters/**",
    "bootstrap/**",
    "rulesets/**",
    "TEMPLATE.md",
    "scenario.schema.json"
  ],
  "injectionHooks": [
    {
      "hookId": "game-start-auth-gate",
      "file": "bootstrap/GameManager.start",
      "functionOrRegion": "GameManager.start()",
      "purpose": "Auth-gated world bootstrap",
      "required": true
    },
    {
      "hookId": "player-input-abstraction",
      "file": "gameplay/input",
      "functionOrRegion": "IPlayerInput",
      "purpose": "Input abstraction for keyboard/controller",
      "required": true
    },
    {
      "hookId": "sync-loop",
      "file": "adapters/multiplayer/SyncManager",
      "functionOrRegion": "SyncManager.tick()",
      "purpose": "Deterministic network sync loop",
      "required": true
    }
  ],
  "requiredGates": [
    "static.immutable_path_violation",
    "static.required_hooks_present",
    "build.app_id_propagation",
    "build.sdk_auth_domain_checks",
    "runtime.preview_probe_evidence",
    "runtime.auth_profile_pass",
    "runtime.matchmaking_pass"
  ],
  "rulesetSchemaRef": "./scenario.schema.json#/definitions/rulesetRef",
  "scenarioSchemaRef": "./scenario.schema.json",
  "baselineMapRef": "./gameplay/maze-layout.json",
  "stylePipeline": {
    "tailwindRequiredWhenUtilityClassesPresent": true,
    "postcssRequired": true
  },
  "enforcement": {
    "defaultMode": "enforce"
  }
}
