# Server Configuration
PORT=3000

# AI Services
GOOGLE_API_KEY=your_google_api_key_here
# Private-key mode (alternative to GOOGLE_API_KEY)
# GOOGLE_SERVICE_ACCOUNT_JSON={"client_email":"service-account@project.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}
# or:
# GOOGLE_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# Viverse SDK Configuration (Pending details)
VIVERSE_SDK_KEY=your_viverse_sdk_key_here

# Logging
LOG_LEVEL=info

# Agent Delegation
VIVERSE_AGENT_ENDPOINT=http://localhost:3000/api/ai/chat

# Browser Auto-Test (Playwright)
# auto: try scripted login
# manual: open headed browser, wait for real user login, then continue tests
VIVERSE_BROWSER_AUTH_MODE=auto
# Optional: force headed mode in auto auth (debug)
VIVERSE_PLAYWRIGHT_HEADFUL=false
# Optional: manual mode wait timeout (ms)
VIVERSE_BROWSER_MANUAL_LOGIN_TIMEOUT_MS=180000
# Optional: persisted storage state path for session reuse across runs
# VIVERSE_PLAYWRIGHT_STORAGE_STATE=/absolute/path/to/storage-state.json
